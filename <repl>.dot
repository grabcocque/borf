digraph ParseTree {
    rankdir=TB;
    node [shape=box, style=filled, fontname="Courier New"];
    edge [color=darkblue, penwidth=1.5];
    0 [fillcolor="lightgreen"];
    1 [fillcolor="lightgreen"];
    2 [fillcolor="lightgreen"];
    3 [fillcolor="lightgreen"];
    4 [fillcolor="lightgreen"];
    0 [ label = "\"✓ repl_input\n(0, 15)\n'_underscore_var'\"" ]
    1 [ label = "\"✓ repl_input\n(0, 15)\n'_underscore_var'\"" ]
    2 [ label = "\"✓ expr\n(0, 15)\n'_underscore_var'\"" ]
    3 [ label = "\"✓ identifier\n(0, 15)\n'_underscore_var'\"" ]
    4 [ label = "\"✓ EOI\n(15, 15)\n'[invalid range]'\"" ]
    0 -> 1 [ ]
    1 -> 2 [ ]
    2 -> 3 [ ]
    1 -> 4 [ ]
}
