--[[ Importing from prelude ]]
@import Prelude { InteractionNetTransform, FullReductionPipeline, >a, >w }

--[[ Basic usage of a pre-composed pipeline ]]
my_result = FullReductionPipeline(WorldState_state)

--[[ Using a parameterized pipeline with a specific output type ]]
reduced_graph = CustomReduction<Graph>(my_wiring_diagram)

--[[ Constructing custom pipelines from imported operators ]]
custom_flow = WorldState | >a | my_filter | >w | my_transformer
