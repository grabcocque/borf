;;Type definitions with minimal decoration
@ACSet: {
  N;
  E;
  s:E.to N;
  t:E.to N;
  lN:N.to X;
  lE:E.to X;
}

@WireDgm<ACSet>: {
  B;
  P;
  b:P.to B;
  w:P.<=> P;
  tP:P.to X;
  tB:B.to X;
}

@INet<WireDgm>: {
  p:P.to{0,1};
}

;;Processing examples
world|>a|>w|>i

>i(>w(>a(world)))

T=t.circ d.circ r.circ i.circ w.circ a(W)
